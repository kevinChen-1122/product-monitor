# ==========================================
# Product Monitor - Environment Variables
# ==========================================
# 說明：
# - 這份檔案提供「可提交到 repo」的範例設定（請勿放真實 webhook/密碼）。
# - 程式讀取的設定集中在 `shared/config/config.go`。
#
# 型別約定：
# - time.Duration：例如 3m、5s、1500ms（Go 的 time.ParseDuration 格式）
#
# ==========================================
# 基本模式 (Required)
# ==========================================
#
# APP_MODE
# - **用途**：控制日誌層級與執行模式
# - **可選值**：dev | prod
# - **預設值**：prod
APP_MODE=prod

# ==========================================
# Redis (Required)
# ==========================================
#
# REDIS_ADDR
# - **用途**：Scheduler/Scraper/Storage/Notifier 使用的 Redis 位址
# - **格式**：host:port
# - **預設值**：localhost:6379
REDIS_ADDR=redis:6379

# ==========================================
# MongoDB (Storage 服務需要)
# ==========================================
#
# MONGO_URI
# - **用途**：MongoDB 連線 URI（Storage 服務使用）
# - **預設值**：mongodb://localhost:27017
MONGO_URI=mongodb://mongodb:27017
#
# MONGO_DB
# - **用途**：MongoDB database 名稱（Storage 寫入用）
# - **預設值**：product_monitor
MONGO_DB=product_monitor
#
# MONGO_COLLECTION
# - **用途**：MongoDB collection 名稱（Storage 寫入用）
# - **預設值**：products
MONGO_COLLECTION=products

# ==========================================
# Scraper 排程/搜尋 (Scheduler 服務需要)
# ==========================================
#
# KEYWORDS
# - **用途**：要搜尋的關鍵字清單（逗號分隔）
# - **預設值**：空（不派發任何任務）
KEYWORDS=iphone,ipad
#
# SCRAPE_INTERVAL
# - **用途**：Scheduler 派發關鍵字到 Redis task queue 的間隔
# - **型別**：time.Duration
# - **預設值**：3m
SCRAPE_INTERVAL=3m

# ==========================================
# Discord 通知 (Notifier / slog 告警)
# ==========================================
#
# DISCORD_WEBHOOK_URLS / DISCORD_WEBHOOK_URL
# - **用途**：新商品通知 webhook（可多個，逗號分隔，會 round-robin 輪詢）
# - **備註**：兩者都支援；`DISCORD_WEBHOOK_URLS` 優先合併，並會去重
DISCORD_WEBHOOK_URLS=
# DISCORD_WEBHOOK_URL=
#
# DISCORD_ALERT_WEBHOOK_URL
# - **用途**：slog Warn/Error 告警專用 webhook
# - **預設行為**：若未填且有設定 DISCORD_WEBHOOK_URL(S)，會沿用第一個 webhook
DISCORD_ALERT_WEBHOOK_URL=

# NOTIFY_DISCORD_BATCH_SIZE
# - **用途**：單次 webhook 最多送幾則 embed（Discord 上限 10）
# - **範圍**：1–10（會自動 clamp）
# - **預設值**：10
NOTIFY_DISCORD_BATCH_SIZE=10
#
# NOTIFY_DISCORD_BATCH_INTERVAL
# - **用途**：自第一筆進隊列起，最多等多久就會送出（與筆數上限擇一觸發）
# - **型別**：time.Duration
# - **最小值**：500ms（過小會被拉到 500ms）
# - **預設值**：5s
NOTIFY_DISCORD_BATCH_INTERVAL=3s